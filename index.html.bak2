    tips:'Travaillez en circuit si possible. Respiration contrôlée. Volume élevé, charge modérée.'
  }
};

function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]]}return a}

function pick(arr, n, exclude=[]){
  const pool=arr.filter(e=>!exclude.includes(e));
  return shuffle([...pool]).slice(0,Math.min(n,pool.length));
}

function getExercisesForMuscle(muscle, level, n, exclude=[]){
  const pool=EXERCISE_POOL[muscle]||[];
  const filtered=pool.filter(e=>{
    if(level==='beginner'&&(e.includes('lesté')||e.includes('lourd')||e.includes('snatch')||e==='Dragon flag'))return false;
    if(level==='advanced'&&(e==='Crunch'||e==='Gainage planche'||e==='Pompes'))return false;
    return true;
  });
  return pick(filtered,n,exclude);
}

function generateWorkout(){
  try {
  const el=document.getElementById('woResult');
  const level=document.getElementById('wLevel').value;
  const goal=document.getElementById('wGoal').value;
  const days=Math.min(6,Math.max(2,parseInt(document.getElementById('wDays').value)||3));
  const weeks=Math.min(12,Math.max(4,parseInt(document.getElementById('wWeeks').value)||8));
  const phase=weeks<=4?0:weeks<=8?1:2;
  const preset=GOAL_PRESETS[goal];
  if(!preset){showToast('Erreur: objectif invalide');return}
  const levelNames={beginner:'Débutant',intermediate:'Intermédiaire',advanced:'Avancé'};
  const goalNames={strength:'Force',hypertrophy:'Prise de Masse',fatloss:'Perte de Poids',endurance:'Endurance'};
  const weekMap={4:'4 sem.',8:'8 sem.',12:'12 sem.'};
  const phaseLabels=['Phase 1 : Adaptation','Phase 2 : Développement','Phase 3 : Intensification'];
  const weekLabels=['Semaine 1-4','Semaine 5-8','Semaine 9-12'];
  const used={};

  const S = (m,n,e)=>getExercisesForMuscle(m,level,n,used[m]||[]).map(x=>{if(!used[m])used[m]=[];used[m].push(x);return x});

  const splits = {
    2:[
      {name:'Full Body A',focus:['chest','back','quads','abs'],compounds:['chest','back'],accessories:['quads','abs']},
      {name:'Full Body B',focus:['hamstrings','shoulders','biceps','triceps','abs'],compounds:['shoulders','hamstrings'],accessories:['biceps','triceps','abs']}
    ],
    3:[
      {name:'PUSH (Pectoraux · Épaules · Triceps)',focus:['chest','shoulders','triceps'],compounds:['chest','shoulders'],accessories:['triceps','abs']},
      {name:'PULL (Dos · Biceps)',focus:['back','biceps','abs'],compounds:['back'],accessories:['biceps','abs']},
      {name:'JAMBES (Quadriceps · Ischios · Mollets)',focus:['quads','hamstrings','calves'],compounds:['quads','hamstrings'],accessories:['calves','abs']}
    ],
    4:[
      {name:'PUSH A (Pec · Épaules)',focus:['chest','shoulders','triceps','abs'],compounds:['chest','shoulders'],accessories:['triceps','abs']},
      {name:'PULL A (Dos · Biceps)',focus:['back','biceps','abs'],compounds:['back'],accessories:['biceps','abs']},
      {name:'PUSH B (Pec · Épaules · Triceps)',focus:['chest','shoulders','triceps','abs'],compounds:['chest','shoulders'],accessories:['triceps','abs']},
      {name:'PULL B (Dos · Jambes)',focus:['back','quads','hamstrings','abs'],compounds:['back','quads'],accessories:['hamstrings','abs']}
    ],
    5:[
      {name:'POITRINE',focus:['chest'],compounds:['chest'],accessories:['shoulders','triceps']},
      {name:'DOS',focus:['back'],compounds:['back'],accessories:['biceps','abs']},
      {name:'JAMBES',focus:['quads','hamstrings','calves'],compounds:['quads','hamstrings'],accessories:['calves','abs']},
      {name:'ÉPAULES',focus:['shoulders'],compounds:['shoulders'],accessories:['abs']},
      {name:'BRAS',focus:['biceps','triceps'],compounds:[],accessories:['biceps','triceps','abs']}
    ],
    6:[
      {name:'PUSH A (Pec · Épaules · Triceps)',focus:['chest','shoulders','triceps'],compounds:['chest','shoulders'],accessories:['triceps']},
      {name:'PULL A (Dos · Biceps)',focus:['back','biceps'],compounds:['back'],accessories:['biceps','abs']},
      {name:'JAMBES (Quadriceps · Ischios)',focus:['quads','hamstrings','calves'],compounds:['quads','hamstrings'],accessories:['calves','abs']},
      {name:'PUSH B (Pec · Épaules · Triceps)',focus:['chest','shoulders','triceps'],compounds:['chest','shoulders'],accessories:['triceps','abs']},
      {name:'PULL B (Dos · Biceps)',focus:['back','biceps','abs'],compounds:['back'],accessories:['biceps']},
      {name:'JAMBES + ABS',focus:['quads','hamstrings','abs'],compounds:['quads','hamstrings'],accessories:['abs']}
    ]
  };

  const split=splits[days]||splits[3];
  const isHiit=goal==='fatloss'||goal==='endurance';
  let html=`<div class="wo-header">
    <div class="meta">
      <strong>${levelNames[level]||level}</strong>
      <span> · ${goalNames[goal]||goal} · ${days}x/sem · ${weekMap[weeks]||weeks+' sem.'}</span>
      <div class="phase">${phaseLabels[phase]} — ${weekLabels[phase]} · ${preset.repRange}</div>
    </div>
    <div class="actions">
      <button type="button" class="btn btn-gold btn-sm" onclick="generateWorkout()" title="Régénérer">↻</button>
      <button type="button" class="btn btn-outline btn-sm" onclick="printWorkout()" title="Imprimer">🖨️</button>
    </div>
  </div>
  <div class="wo-tip">
    <span class="tip-icon">💡</span>
    <div><strong>Conseil :</strong> ${preset.tips}</div>
  </div>`;

  let totalEx=0;
  let gridHtml='';
  split.forEach((day,di)=>{
    const cpd=day.compounds.flatMap(m=>S(m,2)).slice(0,2);
    const acc=day.accessories.flatMap(m=>S(m,isHiit?2:3)).slice(0,4);
    const ordered=isHiit?[...cpd,...acc]:[...cpd,...acc];
    if(!ordered.length)return;
    totalEx+=ordered.length;

    gridHtml+=`<div class="wday-card"><div class="wday-head">
      <div class="wday-num">${di+1}</div>
      <h4>${day.name}</h4>
      <span class="wday-count">${ordered.length} ex.</span>
    </div><div class="wday-body">`;
    ordered.forEach((ex,i)=>{
      const isCompound=i<cpd.length;
      const sets=isCompound?preset.compoudSets[phase]:preset.accSets[phase];
      const reps=isCompound?preset.compoundReps[phase]:preset.accReps[phase];
      const rest=isCompound?preset.compoundRest:preset.accRest;
      const type=isCompound?'compound':'accessory';
      gridHtml+=`<div class="wex-row">
        <div class="wex-name"><span class="wex-dot ${type}"></span><span class="ex-txt">${ex}</span> <span class="wex-badge ${type}">${isCompound?'P':'A'}</span></div>
        <div class="wex-detail"><span class="sets">${sets}×<span class="num">${reps}</span></span><span class="wex-rest">${rest}</span></div>
      </div>`;
    });
    gridHtml+=`</div></div>`;
  });

  if(!totalEx){showToast('Aucun exercice trouvé pour cette sélection');return}
  html+=`<div class="wday-grid">${gridHtml}</div>`;
  el.innerHTML=html;
  el.classList.add('active');
  el.scrollIntoView({behavior:'smooth',block:'start'});
  }catch(e){showToast('Erreur lors de la génération');console.error(e)}
}

function printWorkout(){
  const el=document.getElementById('woResult');
  const content=el.innerHTML;
  if(!content||!el.classList.contains('active')){showToast('Générez d\'abord un programme');return}
  const metaHtml=document.querySelector('.wo-header .meta')?.innerHTML||'';
  const gridHtml=el.querySelector('.wday-grid')?.outerHTML||'';
  if(!gridHtml){showToast('Erreur: programme vide');return}
  const w=window.open('','_blank','width=800,height=600');
  w.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>BodyGlad - Programme</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:Arial,sans-serif;color:#222;background:#fff;padding:40px;font-size:10pt;line-height:1.5}
    .phead{display:flex;align-items:center;gap:16px;padding-bottom:18px;margin-bottom:22px;border-bottom:3px solid #D4AF37}
    .phead img{height:40px;width:auto}
    .phead .info strong{font-size:16pt;display:block;color:#000}
    .phead .info span{font-size:8.5pt;color:#555}
    .pmeta{margin-bottom:22px;font-size:10pt;color:#333;padding:12px 16px;background:#f8f6f0;border-left:3px solid #D4AF37;border-radius:4px}
    .pmeta strong{color:#D4AF37}
    .pmeta .phase{font-size:9pt;color:#D4AF37;margin-top:3px;opacity:.8}
    .wday-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px;justify-content:center}
    .wday-card{break-inside:avoid;border:1px solid #e0d5c0;border-radius:8px;overflow:hidden;margin-bottom:14px}
    .wday-head{display:flex;align-items:center;gap:10px;padding:12px 16px;background:#faf8f4;border-bottom:1px solid #e0d5c0}
    .wday-num{width:28px;height:28px;border-radius:6px;background:#D4AF37;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:10pt;color:#fff;flex-shrink:0}
    .wday-head h4{font-size:10pt;color:#D4AF37;text-transform:uppercase;letter-spacing:.4px;flex:1}
    .wday-count{font-size:8pt;color:#888;background:#f0ede6;padding:2px 8px;border-radius:10px}
    .wday-body{padding:2px 16px 10px}
    .wex-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid #f0ede6;gap:8px}
    .wex-row:last-child{border-bottom:none}
    .wex-name{font-weight:600;font-size:9.5pt;display:flex;align-items:center;gap:6px}
    .wex-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
    .wex-dot.compound{background:#D4AF37}
    .wex-dot.accessory{background:#bbb}
    .wex-badge{font-size:7pt;padding:1px 6px;border-radius:3px;font-weight:700;text-transform:uppercase}
    .wex-badge.compound{background:#f5ede0;color:#D4AF37}
    .wex-badge.accessory{background:#f0f0f0;color:#888}
    .ex-txt{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .wex-detail{display:flex;align-items:center;gap:10px;font-size:9pt;white-space:nowrap}
    .wex-detail .sets{color:#555}
    .wex-detail .num{font-weight:700;color:#000}
    .wex-rest{color:#888;font-size:8pt}
    .pfooter{text-align:center;margin-top:30px;padding-top:16px;border-top:1px solid #ddd;font-size:8pt;color:#999}
    @media print{body{padding:0}@page{margin:1.5cm}}
  </style></head><body>
  <div class="phead">
    <img src="assets/images/logo.png" alt="BodyGlad" onerror="this.style.display='none'">
    <div class="info"><strong>BodyGlad Gym</strong><span>📍 Chéraga, vers GARDEN CITY · 📞 0554 67 22 22 · 🕐 6h-00h · 7j/7</span></div>
  </div>
  <div class="pmeta"><strong>${metaHtml}</strong></div>
  ${gridHtml}
  <div class="pfooter">Programme généré par BodyGlad Gym — www.bodyglad.dz</div>
  <script>window.onload=function(){window.print();window.close()};<\/script>
  </body></html>`);
  w.document.close();
}

