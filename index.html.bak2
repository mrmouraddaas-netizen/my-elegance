function setLang(lang){
  const dict=i18n[lang];
  if(!dict)return;
  document.documentElement.lang=lang;
  if(lang==='ar'){document.body.classList.add('rtl');document.documentElement.dir='rtl'}
  else{document.body.classList.remove('rtl');document.documentElement.dir='ltr'}
  document.querySelectorAll('.lang-btn').forEach(b=>b.classList.toggle('active',b.dataset.lang===lang));
  if(lang==='ar'){document.querySelectorAll('.gradient-text,.section-title,.hero-title,.marquee-letter,.btn').forEach(el=>el.style.fontFamily='var(--font-arabic)')}
  else{document.querySelectorAll('[style*="font-family"]').forEach(el=>{if(el.style.fontFamily.includes('Kufi'))el.style.fontFamily=''})}
  document.querySelectorAll('[data-i18n]').forEach(el=>{
    const key=el.dataset.i18n;const val=dict[key];
    if(val){if(el.tagName==='INPUT'||el.tagName==='TEXTAREA')el.placeholder=val;else el.innerHTML=val}
  });
  renderCart();
  localStorage.setItem('bg_lang',lang);
}

document.querySelectorAll('.lang-btn').forEach(btn=>{
  btn.addEventListener('click',()=>setLang(btn.dataset.lang));
});

// ========== Workout Params Preview ==========
function updateWorkoutPreview(){
  const s=id=>document.getElementById(id);
  const t=id=>{const e=s(id);return e?e.options[e.selectedIndex]?.textContent||'':''};
  s('wpLevel').textContent=t('wLevel');
  s('wpGoal').textContent=t('wGoal');
  const d=s('wDays');s('wpDays').textContent=d?d.value+'j/sem':'';
  s('wpWeeks').textContent=t('wWeeks');
}
document.querySelectorAll('#wLevel,#wGoal,#wDays,#wWeeks').forEach(el=>el.addEventListener('change',updateWorkoutPreview));
setTimeout(updateWorkoutPreview,200);

// ========== Trainer Modal ==========
const trainers=[
  {name:'Coach Ahmed',initials:'CA',gradient:'linear-gradient(135deg,#1a1a2e,#16213e)',roleKey:'coach1-role',bioKey:'coach1-bio',certs:['coach1-cert1','coach1-cert2']},
  {name:'Coach Massi',initials:'CM',gradient:'linear-gradient(135deg,#1e1a2e,#3e1620)',roleKey:'coach2-role',bioKey:'coach2-bio',certs:['coach2-cert1','coach2-cert2']}
];
function openTrainerModal(index){
  const t=trainers[index];
  if(!t)return;
  const lang=document.documentElement.lang||'fr';
  const dict=i18n[lang]||i18n.fr;
  document.getElementById('modalAvatar').textContent=t.initials;
  document.getElementById('modalTrainerName').textContent=t.name;
  document.getElementById('modalTrainerRole').textContent=dict[t.roleKey]||'';
  document.getElementById('modalTrainerBio').textContent=dict[t.bioKey]||'';
  const certsEl=document.getElementById('modalCerts');
  certsEl.innerHTML='';
  (t.certs||[]).forEach(k=>{const v=dict[k];if(v){const b=document.createElement('span');b.className='modal-cert';b.textContent='▸ '+v;certsEl.appendChild(b)}});
  document.getElementById('trainerModal').classList.add('active');
  lockScroll();
}
function closeTrainerModal(){
  document.getElementById('trainerModal').classList.remove('active');
  unlockScroll();
}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeTrainerModal()});

// ========== Schedule Tabs ==========
function switchSchedTab(tab,btn){
  document.querySelectorAll('.sched-tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.sched-panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('sched-'+tab).classList.add('active');
}

// ========== Counter Animation ==========
function animateCounters(){
  document.querySelectorAll('.stat-num[data-count]').forEach(el=>{
    const target=parseInt(el.dataset.count);
    if(!target||el.dataset.animated)return;
    el.dataset.animated='1';
    const suffix=el.dataset.suffix||'';
    const dur=1500;const step=Math.max(1,Math.floor(target/60));
    let cur=0;
    const t=setInterval(()=>{
      cur+=step;if(cur>=target){cur=target;clearInterval(t)}
      el.textContent=suffix?target+suffix:cur.toLocaleString();
    },dur/60);
  });
}

// ========== Counter Observer ==========
const countObserver=new IntersectionObserver((entries)=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting){countObserver.disconnect();animateCounters()}
  });
},{threshold:.3});
const statsSec=document.getElementById('stats');
if(statsSec)countObserver.observe(statsSec);

// ========== INIT ==========
const savedLang=localStorage.getItem('bg_lang')||'fr';
setLang(savedLang);
renderCart();
// Initialize page from URL hash
initPage();

// ========== Scroll animations ==========
const observer=new IntersectionObserver((entries)=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting){entry.target.style.opacity='1';entry.target.style.transform='translateY(0)'}
  });
},{threshold:.1});
document.querySelectorAll('.info-card,.membership-card,.trainer-card,.testimonial-card,.faq-item,.instagram-card,.feature-card,.contact-card,.stat-card,.gallery-item,.partner-card,.schedule-card,.workout-builder').forEach(el=>{
  el.style.opacity='0';el.style.transform='translateY(30px)';el.style.transition='opacity .6s ease,transform .6s ease';
  observer.observe(el);
});
</script>
</body>
</html>
