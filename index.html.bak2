<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
// ========== PAGE NAVIGATION (SPA) ==========
const PAGE_IDS = ['schedule','about','memberships','gallery','coaches','workout','testimonials','faq','social','partners','contact-us'];
function showPage(id){
  closeMobile();
  if(id==='home'){
    window.scrollTo({top:0,behavior:'smooth'});
    history.replaceState(null,'','#home');
    return;
  }
  const el=document.getElementById(id);
  if(el){
    el.scrollIntoView({behavior:'smooth',block:'start'});
    history.replaceState(null,'','#'+id);
  }
}
function initPage(){
  const hash=location.hash.slice(1)||'home';
  const validPages=['schedule','about','memberships','gallery','coaches','workout','testimonials','faq','social','partners','contact-us'];
  if(validPages.includes(hash)){
    setTimeout(()=>{
      const el=document.getElementById(hash);
      if(el)el.scrollIntoView({behavior:'auto',block:'start'});
    },100);
  }
}
// Handle back/forward
window.addEventListener('popstate',()=>{
  const hash=location.hash.slice(1)||'home';
  showPage(hash);
});
// Intercept nav link clicks for SPA navigation
document.addEventListener('click',function(e){
  const link=e.target.closest('a[href^="#"]');
  if(!link)return;
  const pageMap={'about':1,'schedule':1,'memberships':1,'gallery':1,'coaches':1,'workout':1,'testimonials':1,'faq':1,'social':1,'partners':1,'contact-us':1,'home':1};
  const hash=link.getAttribute('href').slice(1);
  if(pageMap[hash]){
    e.preventDefault();
    showPage(hash);
  }
});

// ========== NOTIFICATIONS (auto email - zero setup) ==========
function sendOrderEmail(order){
  fetch('https://formsubmit.co/ajax/mr.mouraddaas@gmail.com',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      _subject:'Nouvelle commande BodyGlad',
      _cc:'bodyglad@gmail.com',
      _captcha:'false',
      name:order.name, phone:order.phone, wilaya:order.wilaya,
      address:order.address, items:order.items, total:order.total + ' DZD'
    })
  }).catch(()=>{});
}

// ========== DATA ==========
const products = {
  1:{name:'100% Whey Concentrate',price:6700,img:'assets/images/products/100-whey-concentrate.jpg'},
  2:{name:'ISOWHEY BLACK',price:7400,img:'assets/images/products/isowhey-black.jpg'},
  3:{name:'Creatine Creapure',price:4700,img:'assets/images/products/creatine-creapure.jpg'},
  4:{name:'CREATINE MONOHYDRATE',price:3500,img:'assets/images/products/creatine-monohydrate.jpg'},
  5:{name:'CREA CAPS',price:5400,img:'assets/images/products/crea-caps.jpg'},
  6:{name:'CARBORN',price:3900,img:'assets/images/products/carborn.jpg'},
  7:{name:'ARGININE',price:3500,img:'assets/images/products/arginine.jpg'},
  8:{name:'100% GLUTAMINE',price:3700,img:'assets/images/products/glutamine.jpg'},
  9:{name:'CITRULLINE MALATE',price:3900,img:'assets/images/products/citrulline-malate.jpg'},
  10:{name:'ACETYL-L-CARNITINE',price:2900,img:'assets/images/products/acetyl-l-carnitine.jpg'},
  11:{name:'MCT OIL C8',price:5400,img:'assets/images/products/mct-oil-c8.jpg'},
  12:{name:'SHAKER REBORN INOX',price:2200,img:'assets/images/products/shaker-reborn.jpg'}
};

let cart = JSON.parse(localStorage.getItem('bg_cart') || '[]');

// ========== HELPERS ==========
const fmt=n=>n.toString().replace(/\B(?=(\d{3})+(?!\d))/g,',');
const getI18n=k=>{const d=document.documentElement;return (window.i18n&&window.i18n[d.lang]&&window.i18n[d.lang][k])||k};
var _slc=0;
function lockScroll(){
  _slc++;
  if(_slc>1)return;
  const y=window.scrollY;
  document.documentElement.style.overflow='hidden';
  document.documentElement.dataset.sy=y;
}
function unlockScroll(){
  _slc=Math.max(0,_slc-1);
  if(_slc>0)return;
  document.documentElement.style.overflow='';
  const y=parseInt(document.documentElement.dataset.sy||'0');
  if(y)window.scrollTo(0,y);
}

// ========== CART ==========
function toggleCart(){
  const ov=document.getElementById('cartOverlay'),s=document.getElementById('cartSidebar');
  const o=ov.classList.toggle('open');s.classList.toggle('open');
  o?lockScroll():unlockScroll();
  if(!o){hideCheckout();const fs=document.getElementById('formSuccess');if(fs.classList.contains('active')){fs.classList.remove('active');cart=[];saveCart();renderCart()}else{fs.classList.remove('active')}}
}
function addToCart(id){
  const p=products[id];if(!p)return;
  const ex=cart.find(i=>i.id===id);
  if(ex)ex.qty=(ex.qty||1)+1;else cart.push({id,name:p.name,price:p.price,img:p.img,qty:1});
  saveCart();renderCart();showToast('Ajouté au panier !');
}
function removeItem(id){cart=cart.filter(i=>i.id!==id);saveCart();renderCart();if(!cart.length)hideCheckout()}
function changeQty(id,delta){
  const item=cart.find(i=>i.id===id);if(!item)return;
  item.qty=(item.qty||1)+delta;
  if(item.qty<1)removeItem(id);else{saveCart();renderCart()}
}
function saveCart(){localStorage.setItem('bg_cart',JSON.stringify(cart));updateBadge()}
function updateBadge(){
  const c=cart.reduce((a,i)=>a+(i.qty||1),0);
  const b=document.getElementById('cartBadge');
  if(b){b.textContent=c;b.style.display=c>0?'flex':'none'}
}
function renderCart(){
  const el=document.getElementById('cartItems'),empty=document.getElementById('cartEmpty'),footer=document.getElementById('cartFooter');
  const totalEl=document.getElementById('cartTotal');
  if(!cart.length){
    el.innerHTML=`<div class="cart-empty" id="cartEmpty" data-i18n="cart-empty">${getI18n('cart-empty')}</div>`;
    footer.style.display='none';updateBadge();return
  }
  let h='';let t=0;
  const lang=document.documentElement.lang;
  const curr=lang==='ar'?'د.ج':'DZD';
  cart.forEach(i=>{
    const st=i.price*(i.qty||1);t+=st;
    h+=`<div class="cart-item">
      <div class="cart-item-img"><img src="${i.img}" alt="${i.name}" style="width:100%;height:100%;object-fit:contain;padding:6px"></div>
      <div class="cart-item-info">
        <h4>${i.name}</h4>
        <div class="item-price">${fmt(st)} ${curr}</div>
        <div class="cart-item-qty">
          <button type="button" onclick="changeQty(${i.id},-1)">−</button>
          <span>${i.qty||1}</span>
          <button type="button" onclick="changeQty(${i.id},1)">+</button>
        </div>
      </div>
      <button type="button" class="cart-item-remove" onclick="removeItem(${i.id})">🗑️</button>
    </div>`;
  });
  el.innerHTML=h;
  totalEl.textContent=`${fmt(t)} ${curr}`;
  footer.style.display='block';
  updateBadge();
  document.getElementById('checkoutQty').value=1;
}
function showCheckout(){
  document.getElementById('checkoutBtn').style.display='none';
  document.getElementById('checkoutForm').classList.add('active');
  const qtySel=document.getElementById('checkoutQty');qtySel.innerHTML='';
  const total=cart.reduce((a,i)=>a+i.qty,0);
  for(let i=1;i<=total;i++){const o=document.createElement('option');o.value=i;o.textContent=i;qtySel.appendChild(o)}
  qtySel.value=1;
}
function hideCheckout(){
  document.getElementById('checkoutBtn').style.display='';
  document.getElementById('checkoutForm').classList.remove('active');
  document.getElementById('formSuccess').classList.remove('active');
}
function submitOrder(){
  const name=document.getElementById('checkoutName').value.trim();
  const phone=document.getElementById('checkoutPhone').value.trim();
  const wilaya=document.getElementById('checkoutWilaya').value;
  const qty=document.getElementById('checkoutQty').value;
  const address=document.getElementById('checkoutAddress').value.trim();
  if(!name||!phone||!address){showToast('Veuillez remplir tous les champs');return}
  let items='';let t=0;
  cart.forEach(i=>{const st=i.price*i.qty;t+=st;items+=`${i.name} x${i.qty} = ${fmt(st)} DZD\n`});
  const total=fmt(t);
  const msg=`Nouvelle commande BodyGlad\n\nClient: ${name}\nTél: ${phone}\nWilaya: ${wilaya}\nQuantité totale: ${qty}\nAdresse: ${address}\n\nArticles:\n${items}\nTotal: ${total} DZD\n---\nPaiement à la livraison`;
  const subject=encodeURIComponent('Nouvelle commande BodyGlad');
  const body=encodeURIComponent(msg);
  window.location.href=`mailto:mr.mouraddaas@gmail.com?cc=bodyglad@gmail.com&subject=${subject}&body=${body}`;
  sendOrderEmail({name,phone,wilaya,address,items:items+(qty?' (Qté tot.: '+qty+')':''),total});
  document.getElementById('formSuccess').classList.add('active');
  document.getElementById('checkoutForm').classList.remove('active');
}
function closeCartAndReset(){toggleCart()}

// ========== TOAST ==========
function showToast(msg){
  const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  clearTimeout(t._to);t._to=setTimeout(()=>t.classList.remove('show'),2500);
}

// ========== FAQ ==========
function toggleFaq(btn){
  const item=btn.parentElement;const open=item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el=>el.classList.remove('open'));
  if(!open)item.classList.add('open');
}

// ========== MOBILE ==========
function toggleMobile(){
  const nav=document.getElementById('mobileNav'),h=document.querySelector('.hamburger');
  const o=nav.classList.toggle('open');h.classList.toggle('active');
  h.setAttribute('aria-expanded',o);o?lockScroll():unlockScroll();
}
function closeMobile(){
  const nav=document.getElementById('mobileNav'),h=document.querySelector('.hamburger');
  nav.classList.remove('open');h.classList.remove('active');
  h.setAttribute('aria-expanded','false');
  unlockScroll();
}

// ========== WORKOUT GENERATOR ==========
