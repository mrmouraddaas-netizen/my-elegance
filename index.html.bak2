<!-- Workout Programs -->
<section class="section" id="workout">
<div class="container">
<div class="wo-wrap">
<div class="wo-head">
<h2 class="section-title"><span class="gradient-text" data-i18n="workout-title">PROGRAMMES</span></h2>
<p class="section-subtitle" data-i18n="workout-sub">Générez votre programme d'entraînement personnalisé</p>
</div>
<div class="wo-body">
<div class="wo-form-row">
<div class="wo-field">
<label><span class="fi">📊</span><span data-i18n="w-level">Niveau</span></label>
<select id="wLevel"><option value="beginner">Débutant</option><option value="intermediate">Intermédiaire</option><option value="advanced">Avancé</option></select>
</div>
<div class="wo-field">
<label><span class="fi">🎯</span><span data-i18n="w-goal">Objectif</span></label>
<select id="wGoal"><option value="strength">Force</option><option value="hypertrophy">Prise de Masse</option><option value="fatloss">Perte de Poids</option><option value="endurance">Endurance</option></select>
</div>
<div class="wo-field">
<label><span class="fi">📅</span><span data-i18n="w-days">Jours / Semaine</span></label>
<select id="wDays"><option value="2">2</option><option value="3" selected>3</option><option value="4">4</option><option value="5">5</option><option value="6">6</option></select>
</div>
<div class="wo-field">
<label><span class="fi">⏱️</span><span data-i18n="w-weeks">Durée</span></label>
<select id="wWeeks"><option value="4">4 sem.</option><option value="8" selected>8 sem.</option><option value="12">12 sem.</option></select>
</div>
<div class="wo-act">
<button type="button" class="btn btn-gold" onclick="generateWorkout()" data-i18n="w-generate">Générer</button>
</div>
</div>
<div class="wo-params" id="woParams"><span>📊 <span class="pv" id="wpLevel">Intermédiaire</span></span><span>🎯 <span class="pv" id="wpGoal">Prise de Masse</span></span><span>📅 <span class="pv" id="wpDays">3j/sem</span></span><span>⏱️ <span class="pv" id="wpWeeks">8 sem.</span></span></div>
</div>
<div class="wo-result" id="woResult"></div>
</div>
</div>
</section>

